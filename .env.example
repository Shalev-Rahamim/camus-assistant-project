  GEMINI_API_KEY=your-gemini-api-key-here

  # Strong secret key for JWT tokens (admin auth)
  SECRET_KEY=change-this-in-production-to-a-long-random-string

  # Optional: override default SQLite DB URL (dev default is campus_assistant.db in backend/)
  # For SQLite (dev):
  # DATABASE_URL=sqlite+aiosqlite:///./campus_assistant.db

  # Example for PostgreSQL (recommended for production):
  # DATABASE_URL=postgresql+asyncpg://user:password@host:5432/campus_assistant